---
import Base from '../layouts/Base.astro'
---

<Base title="404">

  <div id="loading" class="py-12 font-mono text-[0.85rem] text-muted">
    loading...
  </div>

  <div id="consola-post-prompt" class="consola-prompt pt-8"></div>

  <article id="post-view" class="hidden">
    <header class="py-12 border-b border-border mb-10">
      <div id="post-meta"
           class="flex items-center gap-4 font-mono text-[0.72rem] text-muted tracking-widest mb-4">
      </div>
      <h1 id="post-title"
          class="font-serif text-[1.85rem] font-bold leading-tight text-text mt-3">
        <span id="post-title-text"></span><span class="consola-cursor">█</span>
      </h1>
    </header>
    <div id="post-content" class="pb-16 prose dark:prose-invert max-w-none">
    </div>
  </article>

  <div id="not-found" class="hidden py-12">
    <p id="not-found-msg" class="font-mono text-[0.85rem] text-muted">404 — page not found.</p>
    <p class="mt-4 font-mono text-[0.8rem]">
      <a id="home-link" href="/" class="text-accent2">← home</a>
    </p>
  </div>

</Base>

<script>
  import { marked } from 'marked'
  import { translations } from '@/i18n/translations'

  const API_URL  = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001'
  const BASE_URL = import.meta.env.BASE_URL

  function getLang() {
    return (localStorage.getItem('lang') || 'en') as keyof typeof translations
  }

  function i(key: string): string {
    const lang = getLang()
    const keys = key.split('.')
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    let value: any = translations[lang]
    for (const k of keys) value = value?.[k]
    return value ?? key
  }

  function formatDate(dateStr: string): string {
    return new Date(dateStr).toISOString().split('T')[0]
  }

  function applyLang() {
    const loading     = document.getElementById('loading')
    const notFoundMsg = document.getElementById('not-found-msg')
    const homeLink    = document.getElementById('home-link') as HTMLAnchorElement

    if (loading && loading.style.display !== 'none') {
      loading.textContent = i('post.loading')
    }
    if (notFoundMsg) notFoundMsg.textContent = i('post.notFound')
    if (homeLink)    homeLink.textContent    = i('post.backHome')
  }

  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  let cachedPost: any = null

  function renderPost() {
    if (!cachedPost) return
    const lang = getLang()
    const post = cachedPost

    const title   = (lang === 'es' && post.title_es)   ? post.title_es   : post.title
    const content = (lang === 'es' && post.content_es) ? post.content_es : post.content

    document.title = `${title} — dao.log`
    document.getElementById('post-title-text')!.textContent = title

    const rawContent = content.replace(/^#\s+.+\n?/, '')
    document.getElementById('post-content')!.innerHTML = marked(rawContent) as string
  }

  async function init() {
    const loading  = document.getElementById('loading')!
    const postView = document.getElementById('post-view')!
    const notFound = document.getElementById('not-found')!
    const homeLink = document.getElementById('home-link') as HTMLAnchorElement

    loading.textContent = i('post.loading')
    homeLink.href = BASE_URL || '/'

    const path  = window.location.pathname
    const match = path.match(/\/posts\/([^/]+)\/?$/)

    if (!match) {
      loading.style.display = 'none'
      notFound.classList.remove('hidden')
      applyLang()
      return
    }

    const slug = match[1]

    try {
      const res = await fetch(`${API_URL}/api/posts/${slug}`)
      if (!res.ok) throw new Error('not found')
      cachedPost = await res.json()

      document.getElementById('consola-post-prompt')!.textContent = `$ cat /posts/${slug}.md`
      document.getElementById('post-meta')!.innerHTML = `
        <span>${formatDate(cachedPost.published_at)}</span>
        ${cachedPost.tags.map((tag: string) => `<span class="post-tag">${tag}</span>`).join('')}
      `

      renderPost()

      loading.style.display = 'none'
      postView.classList.remove('hidden')

    } catch {
      loading.style.display = 'none'
      notFound.classList.remove('hidden')
      applyLang()
    }
  }

  init()

  window.addEventListener('langchange', () => {
    applyLang()
    renderPost()
  })
</script>

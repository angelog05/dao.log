---
import Base from '../layouts/Base.astro'

const apiUrl  = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001'
const baseUrl = import.meta.env.BASE_URL
---

<Base>
  <ul id="post-list" class="py-12 list-none">
    <li id="loading-item" class="py-12 font-mono text-[0.85rem] text-muted">
      loading...
    </li>
  </ul>
</Base>

<!-- Pass server-side vars to client via data attributes -->
<div id="page-config"
     data-api-url={apiUrl}
     data-base-url={baseUrl}
     style="display:none"></div>

<script>
  import { translations } from '@/i18n/translations'
  import type { Lang } from '@/i18n/translations'

  const config  = document.getElementById('page-config')!
  const apiUrl  = config.dataset.apiUrl!
  const baseUrl = config.dataset.baseUrl!

  function getLang(): Lang {
    return (localStorage.getItem('lang') || 'en') as Lang
  }

  function i(key: string): string {
    const lang = getLang()
    const keys = key.split('.')
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    let value: any = translations[lang]
    for (const k of keys) value = value?.[k]
    return value ?? key
  }

  function formatDate(dateStr: string): string {
    return new Date(dateStr).toISOString().split('T')[0]
  }

  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  let cachedPosts: any[] | null = null

  async function loadPosts() {
    const list        = document.getElementById('post-list')!
    const loadingItem = document.getElementById('loading-item')
    if (loadingItem) loadingItem.textContent = i('index.loading')

    try {
      if (!cachedPosts) {
        const res = await fetch(`${apiUrl}/api/posts`)
        if (!res.ok) throw new Error('API error')
        cachedPosts = await res.json()
      }

      const posts = cachedPosts!

      if (posts.length === 0) {
        list.innerHTML = `
          <li class="py-12 font-mono text-[0.85rem] text-muted">
            ${i('index.empty')}
          </li>`
        return
      }

      const lang = getLang()
      list.innerHTML = posts.map((post: any) => {
        const title   = (lang === 'es' && post.title_es)   ? post.title_es   : post.title
        const excerpt = (lang === 'es' && post.excerpt_es) ? post.excerpt_es : post.excerpt
        return `
        <li class="post-item">
          <div class="consola-prompt">$ cat /posts/${post.slug}.md</div>
          <div class="post-meta">
            <span>${formatDate(post.published_at)}</span>
            ${post.tags.map((tag: string) => `<span class="post-tag">${tag}</span>`).join('')}
          </div>
          <div class="post-title">
            <a href="${baseUrl}/posts/${post.slug}">${title}</a>
          </div>
          ${excerpt ? `<p class="post-excerpt">${excerpt}</p>` : ''}
        </li>`
      }).join('')

    } catch {
      list.innerHTML = `
        <li class="py-12 font-mono text-[0.85rem] text-muted">
          ${i('index.error')}
        </li>`
    }
  }

  loadPosts()

  window.addEventListener('langchange', () => {
    if (cachedPosts !== null) loadPosts()
  })
</script>

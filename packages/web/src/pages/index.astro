---
import Base from '../layouts/Base.astro'
import { getPosts, formatDate } from '../lib/api'

const posts = await getPosts()
---

<Base>
  <ul class="post-list">
    {posts.length === 0 && (
      <li style="padding: 3rem 0; font-family: var(--mono); color: var(--muted); font-size: 0.85rem;">
        no posts yet. the path begins.
      </li>
    )}
    {posts.map(post => (
      <li class="post-item">
        <div class="post-meta">
          <span>{formatDate(post.published_at)}</span>
          {post.tags.map(tag => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
        <div class="post-title">
          <a href={`${import.meta.env.BASE_URL}posts/${post.slug}`}>{post.title}</a>
        </div>
        {post.excerpt && (
          <p class="post-excerpt">{post.excerpt}</p>
        )}
      </li>
    ))}
  </ul>
</Base>

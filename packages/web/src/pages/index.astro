---
import Base from '../layouts/Base.astro'

const apiUrl  = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001'
const baseUrl = import.meta.env.BASE_URL
---

<Base>
  <ul id="post-list" class="py-12 list-none">
    <li id="loading-item" class="py-12 font-mono text-[0.85rem] text-muted">
      loading...
    </li>
  </ul>
</Base>

<script define:vars={{ apiUrl, baseUrl }}>
  import { translations } from '@/i18n/translations'

  function getLang() {
    return (localStorage.getItem('lang') || 'en')
  }

  function i(key) {
    const lang = getLang()
    const keys = key.split('.')
    let value  = translations[lang]
    for (const k of keys) value = value?.[k]
    return value ?? key
  }

  function formatDate(dateStr) {
    return new Date(dateStr).toISOString().split('T')[0]
  }

  let cachedPosts = null

  async function loadPosts() {
    const list        = document.getElementById('post-list')
    const loadingItem = document.getElementById('loading-item')

    if (loadingItem) loadingItem.textContent = i('index.loading')

    try {
      if (!cachedPosts) {
        const res = await fetch(`${apiUrl}/api/posts`)
        if (!res.ok) throw new Error('API error')
        cachedPosts = await res.json()
      }

      const posts = cachedPosts

      if (posts.length === 0) {
        list.innerHTML = `
          <li class="py-12 font-mono text-[0.85rem] text-muted">
            ${i('index.empty')}
          </li>`
        return
      }

      list.innerHTML = posts.map(post => `
        <li class="post-item">
          <div class="consola-prompt">$ cat /posts/${post.slug}.md</div>
          <div class="post-meta">
            <span>${formatDate(post.published_at)}</span>
            ${post.tags.map(tag => `<span class="post-tag">${tag}</span>`).join('')}
          </div>
          <div class="post-title">
            <a href="${baseUrl}/posts/${post.slug}">${post.title}</a>
          </div>
          ${post.excerpt ? `<p class="post-excerpt">${post.excerpt}</p>` : ''}
        </li>
      `).join('')

    } catch {
      list.innerHTML = `
        <li class="py-12 font-mono text-[0.85rem] text-muted">
          ${i('index.error')}
        </li>`
    }
  }

  loadPosts()

  window.addEventListener('langchange', () => {
    if (cachedPosts !== null) loadPosts()
  })
</script>

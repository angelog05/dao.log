---
interface Props {
  title?: string
  description?: string
}

const { title, description } = Astro.props
const siteTitle = 'dao.log'
const siteDesc = 'Notes from the path. AI in the wild, day by day.'
const base = import.meta.env.BASE_URL
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title ? `${title} — ${siteTitle}` : siteTitle}</title>
  <meta name="description" content={description || siteDesc} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <header>
    <div class="container">
      <a class="site-title" href={base}>dao.log</a>
      <div class="site-tagline">notes from the path. ai in the wild, day by day.</div>
      <nav>
        <a href={base}>home</a>
        <a href={`${base}/about`}>about</a>
      </nav>
    </div>
  </header>

  <main>
    <div class="container">
      <slot />
    </div>
  </main>

  <footer>
    <div class="container footer-inner">
      <span>— Bragui</span>
      <span class="footer-dao">道</span>
    </div>
  </footer>

</body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap');

  :root {
    --bg:      #0d0d0d;
    --surface: #141414;
    --border:  #222;
    --text:    #c8c8c0;
    --muted:   #555;
    --accent:  #c8a96e;
    --accent2: #6e9ecb;
    --mono:    'JetBrains Mono', monospace;
    --serif:   'Noto Serif', Georgia, serif;
    --max:     680px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  header { padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--border); }
  .site-title {
    font-family: var(--mono);
    font-weight: 500;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    color: var(--accent);
    text-decoration: none;
  }
  .site-title::before { content: '> '; color: var(--muted); }
  .site-tagline {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 0.3rem;
    letter-spacing: 0.08em;
  }
  nav { margin-top: 1.2rem; display: flex; gap: 1.5rem; }
  nav a {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }
  nav a:hover { color: var(--text); }

  /* Footer */
  footer { padding: 2rem 0; border-top: 1px solid var(--border); margin-top: 2rem; }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--muted);
  }
  .footer-dao { color: var(--accent); font-size: 1.2rem; }

  /* Post list */
  .post-list { padding: 3rem 0; list-style: none; }
  .post-item { padding: 2rem 0; border-bottom: 1px solid var(--border); }
  .post-item:last-child { border-bottom: none; }
  .post-meta {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .post-tag {
    color: var(--accent2);
    border: 1px solid var(--accent2);
    padding: 0.05rem 0.4rem;
    border-radius: 2px;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .post-title {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.6rem;
  }
  .post-title a { color: var(--text); text-decoration: none; transition: color 0.2s; }
  .post-title a:hover { color: var(--accent); }
  .post-excerpt { color: var(--muted); font-size: 0.92rem; line-height: 1.65; }

  /* Post page */
  .post-header { padding: 3rem 0 2rem; border-bottom: 1px solid var(--border); margin-bottom: 2.5rem; }
  .post-header h1 { font-size: 1.85rem; font-weight: 700; line-height: 1.25; color: #e8e8e0; margin-top: 1rem; }

  /* Post content */
  .post-content { padding-bottom: 4rem; }
  .post-content p { margin-bottom: 1.4rem; }
  .post-content h2 {
    font-size: 1.2rem; font-weight: 700; color: #e8e8e0;
    margin: 2.5rem 0 1rem; padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .post-content h3 {
    font-size: 1rem; font-weight: 400; color: var(--accent);
    margin: 2rem 0 0.7rem; font-family: var(--mono); letter-spacing: 0.03em;
  }
  .post-content a { color: var(--accent2); text-decoration: none; border-bottom: 1px solid var(--accent2); transition: color 0.2s; }
  .post-content a:hover { color: var(--text); border-color: var(--muted); }
  .post-content strong { color: #e8e8e0; font-weight: 700; }
  .post-content em { font-style: italic; color: #b0b098; }
  .post-content ul, .post-content ol { margin: 1rem 0 1.4rem 1.5rem; }
  .post-content li { margin-bottom: 0.4rem; }
  .post-content hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .post-content blockquote {
    border-left: 3px solid var(--accent);
    padding: 0.8rem 1.2rem; margin: 1.5rem 0;
    background: var(--surface); color: #a0a090; font-style: italic;
  }

  /* Code */
  code {
    font-family: var(--mono); font-size: 0.85em;
    background: var(--surface); border: 1px solid var(--border);
    padding: 0.1em 0.4em; border-radius: 3px; color: var(--accent);
  }
  pre {
    background: var(--surface); border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    padding: 1.2rem 1.4rem; overflow-x: auto;
    margin: 1.5rem 0; border-radius: 0 4px 4px 0;
  }
  pre code { background: none; border: none; padding: 0; color: var(--text); font-size: 0.82rem; line-height: 1.6; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::selection { background: var(--accent); color: var(--bg); }
</style>
